{
  "expo": {
    "name": "VITAL",
    "slug": "dynavolt",
    "owner": "peregrine.adrift",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/favicon.png",
    "scheme": "dynavolt",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/favicon.png",
      "bundleIdentifier": "com.peregrineadrift.vital"
    },
    "android": {
      "package": "com.peregrineadrift.vital",
      "adaptiveIcon": {
        "backgroundColor": "#0B2545",
        "foregroundImage": "./assets/images/favicon.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "image": "./assets/images/favicon.png",
          "imageWidth": 120
        }
      ],
      "expo-font",
      "expo-web-browser",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "color": "#208AEF",
          "defaultChannel": "alerts-v2"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "2ea9033b-4165-466b-9b1e-8d01c60af1aa"
      }
    }
  }
}
